{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/images/(.*)",
      "dest": "/images/$1"
    },
    {
      "src": "/utsav-html.html",
      "dest": "/utsav-html.html"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
